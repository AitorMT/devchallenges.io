---
import Layout from '@/layouts/Layout.astro'
import { fonts } from '@/consts/fonts'
import { Image } from 'astro:assets'
import BgImage from '@/assets/random-quote/svg/bg-image-random-quote.svg'
import Random from '@/assets/random-quote/svg/regroup.svg'
import Share from '@/assets/random-quote/svg/link.svg'
---

<Layout
  title="Random Quote - devchallenges.io"
  description="A random quote page from Devchallenges.io!"
  fonts={fonts.RandomQuote}
>
  <main
    class="flex h-dvh w-dvw flex-col items-center justify-center gap-4 overflow-hidden bg-[var(--bgColor)] p-4"
  >
    <article
      class="h-min[210px] relative flex w-full flex-col items-center overflow-hidden rounded-lg bg-[var(--bgCard)] sm:w-[500px]"
    >
      <p id="author"></p>
      <div class="flex gap-2" id="tags"></div>
      <blockquote id="quote"></blockquote>
      <BgImage
        aria-hidden="true"
        class="aspect-video object-cover absolute h-full w-full"
      />
    </article>
    <div class="flex gap-3" role="group" aria-label="Quote actions">
      <button
        class="btn flex gap-2 rounded-lg bg-[var(--bgCard)] p-2 transition hover:cursor-pointer hover:brightness-125 active:scale-95"
        id="random-quote-button"
        type="button"
      >
        Random <Random aria-hidden="true" class="inline-block aspect-square" />
      </button>
      <button
        class="btn flex gap-2 rounded-lg bg-[var(--bgCard)] p-2 transition hover:cursor-pointer hover:brightness-125 active:scale-95"
        id="share-quote-button"
        type="button"
      >
        Share <Share aria-hidden="true" class="inline-block aspect-square" />
      </button>
    </div>
  </main>

  <script src="../scripts/random-quote.ts"></script>

  <style slot="head">
    :root {
      --font-family: 'Outfit', 'Adjusted Arial Fallback';
      --largeText: 1.5rem;
      --mediumText: 1rem;
      --smallText: 0.625rem;
      --bgColor: #111629;
      --textColor: #e3e8ef;
      --colorLabel: #aeb0ff;
      --bgCard: #20293a;
      --boxShadow:
        447px 304px 151px 0px rgba(0, 0, 0, 0), 286px 195px 138px 0px rgba(0, 0, 0, 0.01),
        161px 110px 117px 0px rgba(0, 0, 0, 0.05), 72px 49px 87px 0px rgba(0, 0, 0, 0.09),
        18px 12px 48px 0px rgba(0, 0, 0, 0.1);
    }

    #author {
      font-size: var(--mediumText);
      font-weight: bold;
      color: var(--textColor);
      margin-top: 29px;
    }

    #tags {
      margin-top: 8px;
    }

    #quote {
      font-size: var(--largeText);
      color: var(--textColor);
      text-align: center;
      text-wrap: balance;
      z-index: 1;
      margin-top: 20px;
      margin-bottom: 29px;
    }

    .btn {
      color: var(--textColor);
      font-size: var(--mediumText);
    }

    @font-face {
      font-family: 'Adjusted Arial Fallback';
      src: local(Arial);
      size-adjust: 112%;
      ascent-override: 74%;
      descent-override: normal;
      line-gap-override: normal;
    }

    @font-face {
      font-family: 'Outfit';
      src: url('/fonts/Outfit/Outfit-Regular.woff2') format('woff2');
      font-weight: 400;
      font-display: swap;
    }

    @font-face {
      font-family: 'Outfit';
      src: url('/fonts/Outfit/Outfit-Bold.woff2') format('woff2');
      font-weight: 700;
      font-display: swap;
    }

    html {
      font-family: var(--font-family);
    }
  </style>
</Layout>
